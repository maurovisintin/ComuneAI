; Required because react-native-css@0.0.0-nightly.5ce6396 pins
; expo@54.0.0-preview.6 as a peer dep, conflicting with the stable
; expo@54.0.x we install. The newer react-native-css@3.x removes
; this peer pin but has an upstream bug (nativewind/react-native-css#293)
; that breaks Tailwind CSS compilation on native — re-evaluate once
; that issue is fixed.
legacy-peer-deps=true
